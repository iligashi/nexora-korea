APP_NAME="Nexora Cars API"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.nexoracars.com

# Security
FETCH_SECRET=your-strong-random-secret-here

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=nexora_cars
DB_USERNAME=nexora
DB_PASSWORD=your-db-password

# Queue (use database or redis in production)
QUEUE_CONNECTION=redis

# Redis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# AWS S3 for image storage
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-1
AWS_BUCKET=nexora-cars-images
AWS_URL=https://nexora-cars-images.s3.eu-west-1.amazonaws.com

FILESYSTEM_DISK=s3

# Cache
CACHE_DRIVER=redis
SESSION_DRIVER=redis

# Exchange Rate API (free tier at open.er-api.com)
# No key required for open.er-api.com free plan

# Mail (optional)
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_FROM_ADDRESS="hello@nexoracars.com"
MAIL_FROM_NAME="${APP_NAME}"

# CORS — allow Next.js frontend
FRONTEND_URL=https://nexoracars.com
